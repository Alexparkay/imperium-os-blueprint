# ============================================================
# Command Centre - master environment file
# ============================================================
# Copy this file to .env and fill in only the keys you use.
# The root .env is the ONLY env file you edit. Propagate to
# modules with:  node scripts/sync-env.js
# Setup guides per integration: docs/connectors/
# NEVER commit .env (already in .gitignore).
# ============================================================

# --- YouTube transcripts (rules-import/01, automations/youtube/) ---
# Get a token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# --- Owner notifications (rules-import/12, scripts/notify.js, automations/notify/) ---
# Create a bot with @BotFather on Telegram, then get your chat id
# (guide: docs/connectors/telegram-notify.md)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google Workspace (rules-import/08/09, scripts/gdoc-markdown.js) ---
# gws CLI authenticates via OAuth, not an env key. Only set this if
# auto-detection of the gws entry script fails:
# GWS_CLI_JS=/absolute/path/to/@googleworkspace/cli/run-gws.js
GWS_CLI_JS=

# --- AI APIs (optional; used by skills/automations you enable) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Transcription (optional; tools and podcast skills) ---
# No connector guide yet - transcription modules arrive with a full build (docs/connectors/not-yet.md)
ASSEMBLYAI_API_KEY=

# --- Org mode (multi-seat companies only; guide: docs/connectors/org-sync.md) ---
# Git URL of the company's private org context repo. When set, context/org/
# becomes a read-only mirror synced at session start (scripts/org-sync.js).
# Leave unset for single-seat installs.
# ORG_CONTEXT_REPO=git@github.com:<company>/<company>-org-context.git
ORG_CONTEXT_REPO=

# --- Owner basics ---
# IANA timezone, e.g. Europe/London
TIMEZONE=
